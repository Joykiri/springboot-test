<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.MemberInfoMapper">

    <select id="findByIdAndPassword"
            resultType="com.example.demo.DTO.MemberInfoDTO">

        SELECT
            member_id,
            member_name,
            password,
            rec_create_date,
            rec_update_date
        FROM
            MEMBERINFO
        WHERE
            member_id = #{memberId}
        AND
            password = #{password}

    </select>

</mapper>